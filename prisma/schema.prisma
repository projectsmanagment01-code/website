generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Recipe {
  id                  String    @id @default(cuid())
  title               String
  category            String    // DEPRECATED: Keep temporarily for backward compatibility
  categoryId          String?   // NEW: Foreign key to Category model
  description         String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  allergyInfo         String
  author              Json?     // DEPRECATED: Use authorRef relationship instead
  categoryHref        String?   // DEPRECATED: Will be removed after migration
  categoryLink        String    // DEPRECATED: Will be removed after migration
  completeProcess     Json?
  essIngredientGuide  Json?
  faq                 Json?
  featuredText        String
  heroImage           String
  href                String?
  imageAlt            String?
  images              String[]
  img                 String
  featureImage        String?
  cookingImage        String?
  preparationImage    String?
  finalPresentationImage String?
  ingredientGuide     Json?
  intro               String
  mustKnowTips        String[]
  notes               String[]
  nutritionDisclaimer String
  professionalSecrets String[]
  questions           Json?
  recipeInfo          Json?
  relatedRecipes      Json?
  sections            Json?
  serving             String
  shortDescription    String
  slug                String    @unique
  storage             String
  story               String
  testimonial         String
  timing              Json?
  tools               String[]
  updatedDate         String
  whyYouLove          Json?
  ingredients         Json?
  instructions        Json?
  lastViewedAt        DateTime?
  views               Int       @default(0)
  authorId            String?
  status              String    @default("published")
  
  // Relations
  authorRef           Author?            @relation("AuthorRecipes", fields: [authorId], references: [id])
  categoryRef         Category?          @relation("CategoryRecipes", fields: [categoryId], references: [id], onDelete: SetNull)
  spyData             PinterestSpyData[] @relation("SpyDataRecipe")
  
  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
}

model Author {
  id         String              @id @default(cuid())
  name       String
  bio        String?
  img        String?
  avatar     String?
  slug       String              @unique
  link       String?
  tags       String[]            @default([]) // Simple category tags (no relation to Category model)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  recipes    Recipe[]            @relation("AuthorRecipes")

  @@map("authors")
}

model Category {
  id          String   @id @default(cuid())
  name        String   // Display name (e.g., "Evening Meals", "Desserts")
  slug        String   @unique // URL-friendly (e.g., "evening-meals", "desserts")
  description String?  @db.Text // Full description for category page
  image       String   // Dedicated category image (stored in uploads/categories/)
  icon        String?  // Optional icon identifier for UI
  color       String?  // Brand color for category (hex code)
  order       Int      @default(0) // Display order (lower = shown first)
  isActive    Boolean  @default(true) // Active/inactive toggle
  
  // SEO fields
  metaTitle       String?  @db.Text
  metaDescription String?  @db.Text
  
  // Relations
  recipes         Recipe[]          @relation("CategoryRecipes")
  pinterestBoards PinterestBoard[]  @relation("CategoryPinterestBoards")
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([slug])
  @@index([isActive])
  @@index([order])
  @@map("categories")
}

model NavigationItem {
  id            String  @id @default(cuid())
  href          String
  title         String
  iconSrc       String
  iconClassName String
  label         String?
}

model AdminSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// Store site configuration (hero content, site info, social links)
// This prevents config from being overwritten on deployments
model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique // "hero", "site", "social_links"
  data      Json     // Store the entire config object as JSON
  updatedAt DateTime @updatedAt
  updatedBy String?  // Track who made changes
  
  @@map("site_config")
}

// Store all page content (privacy, terms, about, contact, faq, disclaimer, cookies, etc.)
// This prevents content from being overwritten on deployments
model PageContent {
  id              String   @id @default(cuid())
  page            String   @unique // "privacy", "terms", "about", "contact", "faq", "disclaimer", "cookies"
  title           String?  @db.Text
  heroTitle       String?  @db.Text
  heroDescription String?  @db.Text
  heroIntro       String?  @db.Text
  content         String?  @db.Text // HTML or JSON content
  metaTitle       String?  @db.Text
  metaDescription String?  @db.Text
  data            Json?    // Additional structured data (e.g., contact cards, FAQ items)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedBy       String?  // Track who made changes
  
  @@map("page_content")
}

model ApiToken {
  id          String    @id @default(cuid())
  name        String
  token       String    @unique
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  createdBy   String
  description String?

  @@map("api_tokens")
}

model SEOEnhancementReport {
  id                  String   @id @default(cuid())
  recipeId            String
  recipeTitle         String
  status              String   @default("pending") // pending, processing, success, failed
  seoScore            Int?
  enhancementsCount   Int      @default(0)
  processingTime      Int?     // in seconds
  metadataGenerated   Boolean  @default(false)
  imagesProcessed     Int      @default(0)
  linksGenerated      Int      @default(0)
  schemaEnhanced      Boolean  @default(false)
  errorMessage        String?
  aiResponse          Json?    // Store full AI response
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("seo_enhancement_reports")
  @@index([recipeId])
  @@index([status])
  @@index([createdAt])
}

// Media Management System - Tracks all uploaded files with metadata
model Media {
  id            String    @id @default(cuid())
  filename      String    // Sanitized filename on disk (e.g., "chocolate-cake.webp")
  originalName  String    // Original upload filename (e.g., "Chocolate Cake.jpg")
  path          String    // Relative path from uploads root (e.g., "recipes/chocolate-cake.webp")
  url           String    // Public URL to access file (e.g., "/uploads/recipes/chocolate-cake.webp")
  category      String    // File category: recipes, authors, general, categories, ingredients
  mimeType      String    // MIME type (e.g., "image/webp", "image/jpeg")
  size          Int       // File size in bytes
  width         Int?      // Image width in pixels (null for non-images)
  height        Int?      // Image height in pixels (null for non-images)
  thumbnailUrl  String?   // URL to thumbnail version (e.g., "/uploads/recipes/thumb_chocolate-cake.webp")
  
  // Metadata
  alt           String?   // Alt text for accessibility
  caption       String?   // Image caption
  tags          String[]  @default([]) // Searchable tags
  
  // Relationships
  recipeId      String?   // Optional: Link to recipe this image belongs to
  authorId      String?   // Optional: Link to author (for author avatars)
  categoryId    String?   // Optional: Link to category (for category images)
  
  // Audit fields
  uploadedBy    String?   // User ID or admin who uploaded
  uploadedAt    DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Soft delete
  deletedAt     DateTime? // Soft delete timestamp
  
  // Performance indexes
  @@index([category])
  @@index([filename])
  @@index([uploadedAt])
  @@index([recipeId])
  @@index([authorId])
  @@index([categoryId])
  @@unique([category, filename]) // Prevent duplicate filenames within same category
  
  @@map("media")
}

// Ad Management System
model Ad {
  id          String    @id @default(cuid())
  title       String
  description String?
  placement   String    // header, sidebar, footer, inline
  active      Boolean   @default(true)
  adCode      String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime?

  @@map("ads")
}

// Internal Link Suggestions for SEO
model InternalLinkSuggestion {
  id            String    @id @default(cuid())
  sourceRecipeId String
  targetRecipeId String?
  sourceTitle   String?
  targetTitle   String?
  suggestedText String?
  linkType      String?   // "related", "similar", "ingredient", "author"
  status        String    @default("pending") // pending, approved, rejected, applied
  confidence    Float?    // 0-1 confidence score
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("internal_link_suggestions")
  @@index([sourceRecipeId])
  @@index([status])
}

// Hero Slides for Homepage
model HeroSlide {
  id              String    @id @default(cuid())
  title           String    @db.Text
  description     String    @db.Text
  buttonText      String
  buttonLink      String
  backgroundImage String    // URL or path to background image
  order           Int       @default(0) // Display order (lower = shown first)
  isActive        Boolean   @default(true) // Active/inactive toggle
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  updatedBy       String?   // Track who made changes

  @@map("hero_slides")
  @@index([order])
  @@index([isActive])
}

// Automation Settings (stored encrypted in database)
model AutomationSettings {
  id                        String    @id @default(cuid())
  
  // Google Sheets Configuration
  googleSheetId             String?   // The ID of the Google Sheet
  googleSheetUrl            String?   // Full URL for reference
  googleCredentialsJson     String?   @db.Text // Encrypted service account JSON
  
  // AI Configuration
  geminiApiKey              String?   // Encrypted Gemini API key
  geminiFlashModel          String    @default("gemini-2.0-flash-exp")
  geminiProModel            String    @default("gemini-1.5-pro")
  
  // Image Provider Selection
  imageProvider             String    @default("gemini") // "gemini" or "midjourney"
  
  // Midjourney Configuration (GoAPI)
  midjourneyApiKey          String?   // GoAPI API key
  midjourneyWebhookUrl      String?   // Webhook URL for receiving images
  midjourneyPromptTemplate  String?   @db.Text // Prompt template with {recipeName}, {seoKeyword} variables
  midjourneyProcessMode     String    @default("relax") // "relax", "fast", or "turbo"
  
  // Website API Configuration
  websiteApiUrl             String?   // Base URL of your website
  websiteApiToken           String?   // API token for authentication
  
  // Pinterest Integration (Optional)
  enablePinterest           Boolean   @default(false)
  pinterestWebhookUrl       String?   // Make.com webhook URL for Pinterest
  pinterestImageEditPrompt  String?   @db.Text // Custom prompt for editing SpyPin images with Gemini
  
  // Google Indexing (Optional)
  enableIndexing            Boolean   @default(false) // Kept for backward compatibility, use enableGoogleIndexing
  enableGoogleIndexing      Boolean   @default(false)
  googleIndexingCredentials String?   @db.Text // Encrypted Google service account JSON
  
  // Automation Behavior
  maxRetries                Int       @default(3)
  retryDelayMs              Int       @default(5000)
  
  // AI Prompts (Customizable)
  imagePromptSystemPrompt   String?   @db.Text // System prompt for image generation
  recipePromptSystemPrompt  String?   @db.Text // System prompt for recipe generation
  seoPromptSystemPrompt     String?   @db.Text // System prompt for SEO generation
  
  // Status
  isConfigured              Boolean   @default(false) // True when all required fields are set
  lastTestedAt              DateTime?
  testStatus                String?   // "success", "failed", "not_tested"
  testMessage               String?   @db.Text
  
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@map("automation_settings")
}

// Recipe Automation Job Tracking
model RecipeAutomation {
  id                String    @id @default(cuid())
  recipeRowNumber   Int       // Row number in Google Sheet
  status            String    // PENDING, PROCESSING, SUCCESS, FAILED
  currentStep       Int       @default(0)
  totalSteps        Int       @default(12)
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  error             String?   @db.Text
  jobId             String?   // BullMQ job ID
  
  // Recipe details (from sheet)
  spyTitle          String?
  seoKeyword        String?
  recipeId          String?   // Final published recipe ID
  postLink          String?   // Final published URL
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([startedAt])
  @@map("recipe_automation")
}

// Pinterest Spy Data Management
model PinterestSpyData {
  id                    String    @id @default(cuid())
  
  // Raw Pinterest Spy Data (User Input)
  spyTitle              String    @db.Text
  spyDescription        String    @db.Text
  spyImageUrl           String    @db.Text
  spyArticleUrl         String    @db.Text
  spyPinImage           String?   @db.Text
  annotation            String?   @db.Text
  
  // AI-Extracted SEO Metadata
  seoKeyword            String?   @db.Text
  seoTitle              String?   @db.Text
  seoDescription        String?   @db.Text
  seoCategory           String?   @db.Text  // AI-selected category slug from website categories
  
  // AI-Generated Images (4 images per recipe)
  generatedImagePrompts Json?                // Stores all 4 prompts as JSON
  generatedImage1Url    String?   @db.Text  // Feature image URL
  generatedImage2Url    String?   @db.Text  // Ingredients image URL
  generatedImage3Url    String?   @db.Text  // Cooking process image URL
  generatedImage4Url    String?   @db.Text  // Final presentation image URL
  imageGeneratedAt      DateTime?           // When images were generated
  midjourneyTaskId      String?   @db.Text  // Midjourney task ID for webhook tracking
  generatedImages       String[]  @default([]) // Array of generated image paths (from Midjourney or Gemini)
  
  // Processing Status Indicators
  status                String    @default("PENDING") // PENDING, SEO_PROCESSING, SEO_COMPLETED, READY_FOR_GENERATION, GENERATING, COMPLETED, FAILED
  isMarkedForGeneration Boolean   @default(false)
  isProcessed           Boolean   @default(false)
  
  // AI Processing Metadata
  seoProcessedAt        DateTime?
  seoProcessingError    String?   @db.Text
  seoProcessingAttempts Int       @default(0)
  
  // Recipe Generation Tracking
  recipeGeneratedAt     DateTime?
  generatedRecipeId     String?   // Link to created Recipe
  generationError       String?   @db.Text
  generationAttempts    Int       @default(0)
  lastSuccessfulStep    String?   // SEO_COMPLETE, IMAGES_COMPLETE, RECIPE_COMPLETE, GOOGLE_INDEXED, PINTEREST_SENT
  failedAt              DateTime? // When the failure occurred
  failedStep            String?   // Which step failed
  canRetry              Boolean   @default(true) // Whether entry can be retried
  
  // Batch/Import Tracking
  batchId               String?   // For bulk imports
  importedAt            DateTime?
  importedBy            String?   // User ID who imported
  
  // Additional Metadata
  priority              Int       @default(0) // Higher number = higher priority
  tags                  String[]  @default([]) // Custom tags for organization
  notes                 String?   @db.Text     // Internal notes
  
  // Audit Fields
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             String?   // User ID who created
  lastProcessedBy       String?   // User ID who last processed
  
  // Relations
  generatedRecipe       Recipe?   @relation("SpyDataRecipe", fields: [generatedRecipeId], references: [id], onDelete: SetNull)
  
  // Indexes for performance
  @@index([status])
  @@index([isMarkedForGeneration])
  @@index([createdAt])
  @@index([priority])
  @@index([batchId])
  @@index([importedAt])
  
  @@map("pinterest_spy_data")
}

// Automation Scheduler Configuration
model AutomationSchedule {
  id                String    @id @default(cuid())
  enabled           Boolean   @default(false)
  scheduleType      String    @default("manual") // manual, hourly, daily, weekly, custom
  cronExpression    String?   // For custom schedules
  timeOfDay         String?   // HH:MM format for daily schedules
  dayOfWeek         Int?      // 0-6 for weekly schedules (0=Sunday)
  lastRun           DateTime?
  nextRun           DateTime?
  runCount          Int       @default(0)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  executions        PipelineExecutionLog[]

  @@map("automation_schedule")
}

// Pipeline Execution Logs - Track each pipeline run with detailed steps
model PipelineExecutionLog {
  id                String    @id @default(cuid())
  scheduleId        String?   // If triggered by schedule
  schedule          AutomationSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  
  spyDataId         String?   // Entry being processed
  spyTitle          String?   // For easy reference
  
  status            String    @default("RUNNING") // RUNNING, SUCCESS, FAILED
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  durationMs        Int?
  
  // Pipeline stages
  stage             String?   // Which stage it's in or failed at
  progress          Int       @default(0) // 0-100
  
  // Results
  recipeId          String?   // Generated recipe ID
  recipeUrl         String?   // URL to recipe
  
  // Detailed logs
  logs              Json[]    // Array of log entries with timestamps
  
  // Error details
  error             String?   @db.Text
  errorStage        String?   // Which stage failed
  
  // Metadata
  triggeredBy       String    @default("schedule") // schedule, manual, api
  authorId          String?
  
  createdAt         DateTime  @default(now())
  
  @@index([scheduleId])
  @@index([spyDataId])
  @@index([status])
  @@index([createdAt])
  @@map("pipeline_execution_log")
}

// Automation Step Logs - Track each step execution
model AutomationStepLog {
  id              String    @id @default(cuid())
  automationId    String    // References RecipeAutomation.id
  stepNumber      Int       // 1-12
  stepName        String    // "Fetch Google Sheet", "Generate SEO Title", etc.
  status          String    // PENDING, RUNNING, SUCCESS, FAILED
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  durationMs      Int?      // Duration in milliseconds
  
  // Data passed in/out of step
  inputData       Json?     // What went into this step
  outputData      Json?     // What came out of this step
  
  // Configuration used for this step
  config          Json?     // Prompt, model, image settings, etc.
  
  // Error details
  error           String?   @db.Text
  stackTrace      String?   @db.Text
  
  // Cost tracking (for AI steps)
  tokensUsed      Int?
  costUsd         Decimal?  @db.Decimal(10, 6)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([automationId])
  @@index([stepNumber])
  @@index([status])
  @@map("automation_step_logs")
}

// Pinterest Board Mapping - Maps categories to Pinterest boards
model PinterestBoard {
  id          String    @id @default(cuid())
  boardName   String    // Display name of Pinterest board
  boardId     String    // Pinterest board ID from Pinterest
  categoryId  String    // Foreign key to Category model
  category    Category  @relation("CategoryPinterestBoards", fields: [categoryId], references: [id], onDelete: Cascade)
  
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([categoryId]) // One board per category
  @@index([categoryId])
  @@index([isActive])
  @@map("pinterest_boards")
}

// Google Tag Manager Settings
model GTMSettings {
  id              String   @id @default(cuid())
  gtmId           String?  // GTM-XXXXXXX
  ga4Id           String?  // G-XXXXXXXXXX
  enableGTM       Boolean  @default(false)
  enableGA4       Boolean  @default(false)
  consentMode     Boolean  @default(true) // Enable Google Consent Mode v2
  customHeadCode  String?  @db.Text // Additional custom code for <head>
  customBodyCode  String?  @db.Text // Additional custom code for <body>
  customFooterCode String? @db.Text // Additional custom code before </body>
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("gtm_settings")
}
